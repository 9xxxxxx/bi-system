# FastAPI environment
BI_ENVIRONMENT=development
BI_DATABASE_URL=sqlite+pysqlite:///./data/bi_system.db
BI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BI_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
BI_STORAGE_ROOT=data/uploads
BI_UPLOAD_MAX_BYTES=104857600
BI_XLSX_MAX_UNCOMPRESSED_BYTES=1073741824
BI_XLSX_MAX_COMPRESSION_RATIO=200
BI_IMPORT_MAX_ROWS=1000000
BI_IMPORT_CHUNK_ROWS=2000
BI_PREVIEW_MAX_ROWS=100

# PostgreSQL example for test or shared environments
# BI_DATABASE_URL=postgresql+psycopg://bi_system:bi_system@127.0.0.1:5432/bi_system
